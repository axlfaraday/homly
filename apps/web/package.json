{
  "name": "@homly/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && NEXT_DISABLE_WEBPACK_CACHE=1 next dev -p 3000",
